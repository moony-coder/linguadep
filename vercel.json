{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-cc62.up.railway.app/api/:path*"
    },
    {
      "source": "/live",
      "destination": "wss://backend-production-cc62.up.railway.app/live"
    },
    {
      "source": "/:path((?!.*\\.).*)*",
      "destination": "/index.html"
    }
  ]
}
