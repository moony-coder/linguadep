# Required runtime secrets for the backend
GEMINI_API_KEY=your-gemini-api-key

# Optional Gemini key pools for tiered usage
FREE_KEYS="your-free-key-1,your-free-key-2"
CASUAL_KEYS="your-casual-key-1"
PREMIUM_KEYS="your-premium-key-1,your-premium-key-2"
EMERGENCY_KEYS="your-emergency-key-1,your-emergency-key-2"

# Optional Telegram bot token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# App URL for runtime links (not required for backend service)
APP_URL=https://your-frontend-url

# Supabase config (if used by the frontend)
VITE_SUPABASE_URL=https://your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# This repo is configured for split deployment:
# - Railway backend uses `npm run build:backend` and `npm run start:backend`
# - Vercel frontend uses `npm run build`
# Local frontend override values:
# VITE_API_BASE_URL=http://localhost:3000
# VITE_REALTIME_WS_URL=ws://localhost:3000
